# Ejemplo de variables de entorno
# Copiar este archivo a .env y ajustar según tu configuración

# ============================================================================
# API & BACKEND
# ============================================================================

# URL base de la API del backend
REACT_APP_API_URL=http://localhost:3001/api

# URL del WebSocket para datos en tiempo real
REACT_APP_WS_URL=ws://localhost:8080

# ============================================================================
# APLICACIÓN
# ============================================================================

# Ambiente (development, staging, production)
REACT_APP_ENV=development

# Nombre de la aplicación
REACT_APP_NAME=Monitor Clínico 6MWT

# Versión de la aplicación
REACT_APP_VERSION=1.0.0

# ============================================================================
# CONFIGURACIÓN DE TIMEOUT
# ============================================================================

# Timeout para peticiones API en milisegundos
REACT_APP_API_TIMEOUT=30000

# Timeout para WebSocket en milisegundos
REACT_APP_WS_TIMEOUT=10000

# ============================================================================
# FEATURES & FLAGS
# ============================================================================

# Habilitar modo demo
REACT_APP_DEMO_MODE=true

# Habilitar exportación a PDF
REACT_APP_EXPORT_PDF=true

# Habilitar exportación a CSV
REACT_APP_EXPORT_CSV=true

# Habilitar sincronización en la nube
REACT_APP_CLOUD_SYNC=false

# ============================================================================
# SERVICIOS EXTERNOS (Opcional)
# ============================================================================

# Google Analytics
REACT_APP_GA_ID=

# Sentry error tracking
REACT_APP_SENTRY_DSN=

# SendGrid para email
REACT_APP_SENDGRID_API_KEY=

# ============================================================================
# DEBUG
# ============================================================================

# Habilitar logs en consola
REACT_APP_DEBUG=true

# Habilitar datos mock
REACT_APP_USE_MOCK_DATA=true
